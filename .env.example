## Server
PORT=3000
# Behind a reverse proxy, set so per-IP rate limits use the client IP (see express trust proxy).
# TRUST_PROXY=1
# Optional: disable all API rate limiters (local debugging only).
# DISABLE_RATE_LIMIT=true

## Community directory (optional)
# Caps GET /community/members and the same cap when validating POST /chats peer DMs (default 100, max 500).
# COMMUNITY_MEMBER_LIMIT=100

## Firestore indexes
# Deploy composite indexes (required before switching `firestoreRepo.js` back to orderBy):
#   firebase deploy --only firestore:indexes

# Local `npm run dev` / `npm start` load this file via `dotenv` (see `index.js`).

## Auth
# All protected routes require a Firebase ID token: Authorization: Bearer <idToken>

## Firebase Admin credentials (choose ONE approach)
#
# Firestore: when USE_FIRESTORE is unset, persistence turns on if credentials
# (GOOGLE_APPLICATION_CREDENTIALS or FIREBASE_SERVICE_ACCOUNT_JSON) are set.
# USE_FIRESTORE=true
# USE_FIRESTORE=false
#
# Option A (recommended): point to a service account file
# (do NOT commit it; `serviceAccountKey.json` is already in `.gitignore`)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
#
# Option B: inline JSON (useful for some deploy platforms)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

## Firebase Storage (required for manual identity verification uploads)
# Local dev: either name works. For Firebase Functions deploy, prefer STORAGE_BUCKET because
# Firebase reserves env keys starting with FIREBASE_.
#
# Example bucket ids:
# - hercircle-389f0.firebasestorage.app
# - hercircle-389f0.appspot.com
#
# Cloud Run / Functions: set this explicitly. The Cloud Run service account needs permission
# to create objects (e.g. roles/storage.objectAdmin on the bucket, or use the Firebase Admin role).
#
# GitHub Actions deploy: add the same value as a repository Variable named STORAGE_BUCKET
# (Settings → Secrets and variables → Actions → Variables). The workflow writes .env on the runner.
# `firebaseParams.js` registers STORAGE_BUCKET with Firebase so it is applied to Cloud Run at deploy.
STORAGE_BUCKET=
FIREBASE_STORAGE_BUCKET=

## Admin review (manual verification MVP)
# Allowlist admin reviewers by UID or email (comma-separated). Prefer Firebase custom claims when possible.
# ADMIN_UIDS=uid1,uid2
# ADMIN_EMAILS=admin@example.com

