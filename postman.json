{
  "info": {
    "name": "HerCircle API (local)",
    "_postman_id": "7c2f0c2b-0c6a-4c6b-9f2a-000000000001",
    "description": "Import this into Postman.\n\nSet collection variables:\n- baseUrl (default http://localhost:3000)\n- firebaseIdToken (paste a Firebase ID token)\n- exampleUserId / exampleRequestId (IDs from your data, e.g. feed or POST responses)\n\nNotes:\n- Protected routes require: Authorization: Bearer {{firebaseIdToken}}\n- Use the Firebase Auth folder first (signUp or signIn) to populate firebaseIdToken.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "firebaseApiKey", "value": "" },
    { "key": "firebaseEmail", "value": "" },
    { "key": "firebasePassword", "value": "" },
    { "key": "firebaseIdToken", "value": "" },
    { "key": "exampleUserId", "value": "" },
    { "key": "exampleRequestId", "value": "" },
    { "key": "chatId", "value": "" },
    { "key": "sosId", "value": "" }
  ],
  "item": [
    {
      "name": "Firebase Auth (REST) — get ID token",
      "item": [
        {
          "name": "POST Firebase signUp (email/password)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{firebaseEmail}}\",\n  \"password\": \"{{firebasePassword}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebaseApiKey}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.idToken) {",
                  "  pm.collectionVariables.set('firebaseIdToken', json.idToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Firebase signInWithPassword (email/password)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{firebaseEmail}}\",\n  \"password\": \"{{firebasePassword}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.idToken) {",
                  "  pm.collectionVariables.set('firebaseIdToken', json.idToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
