rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Client SDK access is denied. The HerCircle API uses the Admin SDK, which
    // bypasses these rules. Tighten or add collection rules here if a client
    // ever reads/writes Firestore directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
